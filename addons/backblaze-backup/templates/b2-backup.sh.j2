#!/bin/bash
# Backblaze B2 Backup Script — multi-job sync
# Performs incremental backup to Backblaze B2 using rclone
# Generated by Ansible — do not edit manually.

set -euo pipefail

SCRIPT_NAME="$(basename "$0")"
LOG_FILE="{{ backup_log_path }}/backup.log"
RCLONE_REMOTE="{{ rclone_config_name }}"

log() { echo "[$(date '+%Y-%m-%d %H:%M:%S')] [$SCRIPT_NAME] $1" | tee -a "$LOG_FILE"; }
error() { log "ERROR: $1"; exit 1; }

# Exclude patterns
EXCLUDE_ARGS=(
{% for pattern in backup_exclude_patterns %}
  --exclude "{{ pattern }}"
{% endfor %}
)

# Create snapshot before backup
create_snapshot() {
{% if backup_use_snapshots | default(true) | bool %}
    if command -v snapper &>/dev/null; then
        snapper -c root create --description "backup-$(date +%Y%m%d-%H%M%S)" --cleanup-algorithm number 2>/dev/null || \
            log "Warning: Failed to create snapshot, continuing with live backup"
    fi
{% endif %}
}

# Sync a single job
sync_job() {
    local name="$1"
    local source="$2"
    local bucket="$3"

    if [[ ! -d "$source" ]]; then
        log "Warning: Source $source does not exist, skipping job '$name'"
        return 0
    fi

    log "[$name] Syncing $source → $RCLONE_REMOTE:$bucket"

    if rclone sync "$source" "$RCLONE_REMOTE:$bucket" \
        "${EXCLUDE_ARGS[@]}" \
        --transfers 4 \
        --checkers 8 \
        --fast-list \
        --stats-one-line \
        --stats 60s \
        --log-level INFO \
        2>&1 | tee -a "$LOG_FILE"; then
        log "[$name] Sync completed"
    else
        log "[$name] ERROR: Sync failed (exit $?)"
        return 1
    fi
}

# Show status of all jobs
show_status() {
{% for job in backup_jobs %}
    echo "=== {{ job.name }} ==="
    echo "  Source: {{ job.source }}"
    echo "  Bucket: {{ job.bucket }}"
    if rclone size "$RCLONE_REMOTE:{{ job.bucket }}" --json 2>/dev/null | python3 -c "
import sys, json
d = json.load(sys.stdin)
print(f\"  Remote: {d['count']} files, {d['bytes']/1e9:.1f} GB\")
" 2>/dev/null; then true; else echo "  Remote: cannot connect"; fi
    echo ""
{% endfor %}
    echo "Timer: $(systemctl is-active {{ backup_timer_name }} 2>/dev/null || echo 'not running')"
    echo "Last run: $(systemctl show {{ backup_service_name }} -p ExecMainStartTimestamp --value 2>/dev/null || echo 'never')"
}

# Main backup
main() {
    if [[ $EUID -ne 0 ]]; then error "Must run as root"; fi

    command -v rclone &>/dev/null || error "rclone not found"
    rclone config show "$RCLONE_REMOTE" &>/dev/null || error "rclone remote '$RCLONE_REMOTE' not configured"

    log "Starting backup ({{ backup_jobs | length }} jobs)"

    create_snapshot

    local failures=0
{% for job in backup_jobs %}
    sync_job "{{ job.name }}" "{{ job.source }}" "{{ job.bucket }}" || ((failures++))
{% endfor %}

    if [[ $failures -eq 0 ]]; then
        log "All backup jobs completed successfully"
        logger -t "$SCRIPT_NAME" "Backup: SUCCESS ({{ backup_jobs | length }} jobs)"
    else
        log "WARNING: $failures job(s) failed"
        logger -t "$SCRIPT_NAME" "Backup: $failures FAILURES"
        exit 1
    fi
}

case "${1:-backup}" in
    backup)  main ;;
    status)  show_status ;;
    help|-h) echo "Usage: $0 {backup|status|help}" ;;
    *)       error "Unknown: $1" ;;
esac
