#!/bin/bash
# Backup Monitor — check backup health
set -euo pipefail

RCLONE_REMOTE="{{ rclone_config_name }}"
issues=0

echo "=== Backup Monitor ==="
echo ""

# Timer status
timer_status=$(systemctl is-active {{ backup_timer_name }} 2>/dev/null || echo "inactive")
echo "Timer: $timer_status"
if [[ "$timer_status" != "active" ]]; then
    echo "  ✗ Backup timer is not active!"
    ((issues++))
else
    echo "  ✓ Backup timer running"
fi

# Last run
last_run=$(systemctl show {{ backup_service_name }} -p ExecMainStartTimestamp --value 2>/dev/null || echo "")
last_result=$(systemctl show {{ backup_service_name }} -p Result --value 2>/dev/null || echo "")
echo ""
echo "Last run: ${last_run:-never}"
echo "Result: ${last_result:-unknown}"

if [[ "$last_result" == "success" ]]; then
    echo "  ✓ Last backup succeeded"
elif [[ -n "$last_result" && "$last_result" != "unknown" ]]; then
    echo "  ✗ Last backup failed"
    ((issues++))
fi

# B2 connectivity
echo ""
echo "Connectivity:"
if rclone lsd "$RCLONE_REMOTE:" &>/dev/null; then
    echo "  ✓ B2 reachable"
else
    echo "  ✗ Cannot reach B2"
    ((issues++))
fi

# Bucket sizes
echo ""
echo "Buckets:"
{% for job in backup_jobs %}
if rclone size "$RCLONE_REMOTE:{{ job.bucket }}" --json 2>/dev/null | python3 -c "
import sys, json
d = json.load(sys.stdin)
print(f'  {{ job.name }}: {d[\"count\"]} files, {d[\"bytes\"]/1e9:.1f} GB')
" 2>/dev/null; then true; else echo "  {{ job.name }}: cannot read"; ((issues++)); fi
{% endfor %}

echo ""
if [[ $issues -eq 0 ]]; then
    echo "Status: ✓ All checks passed"
    logger -t "backup-monitor" "Backup monitor: OK"
else
    echo "Status: ✗ $issues issue(s) found"
    logger -p user.warn -t "backup-monitor" "Backup monitor: $issues issues"
fi
