#!/bin/bash
# Backup Restore — restore from B2 bucket
set -euo pipefail

RCLONE_REMOTE="{{ rclone_config_name }}"

show_usage() {
    echo "Usage: $0 [--list | --dry-run] <job-name> <restore-path>"
    echo ""
    echo "Available jobs:"
{% for job in backup_jobs %}
    echo "  {{ job.name }}  ({{ job.bucket }})"
{% endfor %}
    echo ""
    echo "Examples:"
    echo "  $0 --list                        # Show what's in each bucket"
    echo "  $0 --dry-run photos /tmp/restore  # Preview restore"
    echo "  $0 photos /tmp/restore            # Actual restore"
}

list_buckets() {
{% for job in backup_jobs %}
    echo "=== {{ job.name }} ({{ job.bucket }}) ==="
    rclone size "$RCLONE_REMOTE:{{ job.bucket }}" 2>/dev/null || echo "Cannot connect"
    echo ""
{% endfor %}
}

case "${1:---help}" in
    --list|-l)   list_buckets; exit 0 ;;
    --help|-h|help) show_usage; exit 0 ;;
esac

DRY_RUN=""
if [[ "${1:-}" == "--dry-run" || "${1:-}" == "-d" ]]; then
    DRY_RUN="--dry-run"
    shift
fi

JOB_NAME="${1:-}"
RESTORE_PATH="${2:-}"

if [[ -z "$JOB_NAME" || -z "$RESTORE_PATH" ]]; then
    show_usage; exit 1
fi

# Map job name to bucket
BUCKET=""
{% for job in backup_jobs %}
[[ "$JOB_NAME" == "{{ job.name }}" ]] && BUCKET="{{ job.bucket }}"
{% endfor %}

if [[ -z "$BUCKET" ]]; then
    echo "Unknown job: $JOB_NAME"
    show_usage; exit 1
fi

mkdir -p "$RESTORE_PATH"
echo "Restoring $JOB_NAME ($RCLONE_REMOTE:$BUCKET) → $RESTORE_PATH"
[[ -n "$DRY_RUN" ]] && echo "(dry run — no files will be written)"

rclone sync "$RCLONE_REMOTE:$BUCKET" "$RESTORE_PATH" \
    $DRY_RUN \
    --progress \
    --stats-one-line \
    --stats 30s

echo "Done."
