#!/bin/bash
# Backup Verification — checks all jobs against B2
set -euo pipefail

RCLONE_REMOTE="{{ rclone_config_name }}"
errors=0

echo "=== Backup Verification ==="
{% for job in backup_jobs %}
echo ""
echo "--- {{ job.name }} ---"
echo "  Source: {{ job.source }}"
echo "  Bucket: {{ job.bucket }}"

if [[ -d "{{ job.source }}" ]]; then
    local_size=$(du -sb "{{ job.source }}" 2>/dev/null | cut -f1 || echo 0)
    remote_info=$(rclone size "$RCLONE_REMOTE:{{ job.bucket }}" --json 2>/dev/null || echo '{"bytes":0,"count":0}')
    remote_bytes=$(echo "$remote_info" | jq -r '.bytes // 0')
    remote_count=$(echo "$remote_info" | jq -r '.count // 0')

    echo "  Local: $((local_size / 1048576)) MB"
    echo "  Remote: $((remote_bytes / 1048576)) MB ($remote_count files)"

    if [[ "$remote_bytes" -eq 0 ]]; then
        echo "  STATUS: ✗ Remote is empty"
        ((errors++))
    elif [[ "$remote_bytes" -lt "$((local_size * 50 / 100))" ]]; then
        echo "  STATUS: ! Remote significantly smaller than local"
    else
        echo "  STATUS: ✓ OK"
    fi
else
    echo "  STATUS: ! Source path does not exist"
fi
{% endfor %}

echo ""
if [[ $errors -eq 0 ]]; then
    echo "All jobs verified."
else
    echo "$errors job(s) have issues."
    exit 1
fi
