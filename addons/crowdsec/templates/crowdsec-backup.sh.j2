#!/bin/bash
# CrowdSec Backup Script
# Generated by Ansible

set -euo pipefail

BACKUP_DIR="{{ crowdsec_backup_path }}"
DATE="$(date +%Y%m%d-%H%M%S)"
BACKUP_FILE="$BACKUP_DIR/crowdsec-backup-$DATE.tar.gz"
RETENTION_DAYS={{ crowdsec_retention_days }}

echo "[INFO] Starting CrowdSec backup..."

mkdir -p "$BACKUP_DIR"

# Backup CrowdSec config and data
tar czf "$BACKUP_FILE" \
  -C / \
  "{{ crowdsec_config_path | regex_replace('^/', '') }}" \
  "{{ crowdsec_data_path | regex_replace('^/', '') }}/crowdsec.db" \
  2>/dev/null || true

# Backup decisions
cscli decisions export -o "$BACKUP_DIR/decisions-$DATE.json" 2>/dev/null || true

# Cleanup old backups
find "$BACKUP_DIR" -name "crowdsec-backup-*.tar.gz" -mtime +$RETENTION_DAYS -delete 2>/dev/null || true
find "$BACKUP_DIR" -name "decisions-*.json" -mtime +$RETENTION_DAYS -delete 2>/dev/null || true

echo "[SUCCESS] Backup saved: $BACKUP_FILE"
