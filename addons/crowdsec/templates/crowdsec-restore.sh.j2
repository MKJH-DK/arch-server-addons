#!/bin/bash
# CrowdSec Restore Script
# Generated by Ansible

set -euo pipefail

BACKUP_DIR="{{ crowdsec_backup_path }}"

if [[ $# -lt 1 ]]; then
  echo "Usage: $0 <backup-file.tar.gz>"
  echo ""
  echo "Available backups:"
  ls -1t "$BACKUP_DIR"/crowdsec-backup-*.tar.gz 2>/dev/null | head -10 || echo "  (none)"
  exit 1
fi

BACKUP_FILE="$1"

if [[ ! -f "$BACKUP_FILE" ]]; then
  echo "[ERROR] Backup file not found: $BACKUP_FILE"
  exit 1
fi

echo "[INFO] Stopping CrowdSec services..."
systemctl stop crowdsec-firewall 2>/dev/null || true
systemctl stop crowdsec

echo "[INFO] Restoring from: $BACKUP_FILE"
tar xzf "$BACKUP_FILE" -C /

# Restore decisions if available
DECISIONS_FILE="${BACKUP_FILE/crowdsec-backup/decisions}"
DECISIONS_FILE="${DECISIONS_FILE/.tar.gz/.json}"
if [[ -f "$DECISIONS_FILE" ]]; then
  echo "[INFO] Restoring decisions..."
  cscli decisions import -i "$DECISIONS_FILE" 2>/dev/null || true
fi

echo "[INFO] Starting CrowdSec services..."
systemctl start crowdsec
systemctl start crowdsec-firewall

echo "[SUCCESS] CrowdSec restored from backup"
