# CrowdSec Custom Scenarios
# Generated by Ansible — addon-level security scenarios

type: leaky
name: custom/web-attacks
description: "Detect common web attack patterns (SQLi, XSS, path traversal, RCE)"
filter: "evt.Meta.log_type in ['caddy', 'nginx', 'apache']"
groupby: "evt.Meta.source_ip"
capacity: 5
leakspeed: 30s
blackhole: 5m
labels:
  type: web
  remediation: true

---
type: leaky
name: custom/ssh-aggressive
description: "Detect aggressive SSH brute force (faster threshold than default)"
filter: "evt.Meta.log_type == 'syslog' && evt.Meta.service == 'sshd' && evt.Meta.action == 'failed'"
groupby: "evt.Meta.source_ip"
capacity: 3
leakspeed: 10s
blackhole: 15m
labels:
  type: ssh
  remediation: true

---
type: leaky
name: custom/api-abuse
description: "Detect API endpoint abuse (excessive requests)"
filter: "evt.Meta.log_type in ['caddy', 'nginx'] && evt.Parsed.http_path startsWith '/api/'"
groupby: "evt.Meta.source_ip"
capacity: 50
leakspeed: 1s
blackhole: 10m
labels:
  type: api
  remediation: true

---
type: leaky
name: custom/scanner-detection
description: "Detect vulnerability scanners by common paths"
filter: |
  evt.Meta.log_type in ['caddy', 'nginx', 'apache'] &&
  (evt.Parsed.http_path contains '.env' ||
   evt.Parsed.http_path contains 'wp-admin' ||
   evt.Parsed.http_path contains 'wp-login' ||
   evt.Parsed.http_path contains '.git/' ||
   evt.Parsed.http_path contains 'phpinfo' ||
   evt.Parsed.http_path contains 'phpmyadmin' ||
   evt.Parsed.http_path contains 'xmlrpc.php' ||
   evt.Parsed.http_path contains '/admin/' ||
   evt.Parsed.http_path contains '/.well-known/security.txt' == false)
groupby: "evt.Meta.source_ip"
capacity: 3
leakspeed: 30s
blackhole: 24h
labels:
  type: scanner
  remediation: true
