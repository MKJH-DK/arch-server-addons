#!/bin/bash
# CrowdSec Quick Status
# Generated by Ansible

set -euo pipefail

RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m'

ok()   { echo -e "${GREEN}✓${NC} $1"; }
warn() { echo -e "${YELLOW}!${NC} $1"; }
fail() { echo -e "${RED}✗${NC} $1"; }

echo "CrowdSec Status"
echo "═══════════════"

# Services
systemctl is-active --quiet crowdsec          && ok "Agent: running"          || fail "Agent: stopped"
systemctl is-active --quiet crowdsec-firewall && ok "Firewall bouncer: running" || warn "Firewall bouncer: stopped"

# API
curl -sf "http://localhost:{{ crowdsec_agent_port }}/v1/metrics" >/dev/null 2>&1 \
  && ok "API: responsive (port {{ crowdsec_agent_port }})" \
  || fail "API: not responding"

# Decisions
echo ""
echo "Active decisions:"
cscli decisions list -l 10 --no-api 2>/dev/null || warn "Could not list decisions"

# Alerts (last 24h)
echo ""
echo "Recent alerts (24h):"
cscli alerts list --since 24h -l 5 2>/dev/null || warn "Could not list alerts"

# Bouncers
echo ""
echo "Registered bouncers:"
cscli bouncers list 2>/dev/null || warn "Could not list bouncers"
