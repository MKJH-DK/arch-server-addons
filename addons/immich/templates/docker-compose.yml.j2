version: '3.8'
# Immich - Podman Compose (host networking)
# Generated by Ansible (immich addon). Do not edit manually.
#
# Uses host networking because hardened kernels lack bridge support.
# All services bind to localhost on their respective ports.

services:
  immich-server:
    image: ghcr.io/immich-app/immich-server:{{ immich_version }}
    container_name: immich-server
    restart: unless-stopped
    command: ['start.sh', 'immich']
    network_mode: host
    environment:
      - NODE_ENV={{ immich_environment }}
    env_file:
      - {{ immich_docker_env_path }}
    volumes:
      - {{ immich_upload_path }}:/usr/src/app/upload
      - {{ immich_library_path }}:/usr/src/app/library
      - {{ immich_thumb_path }}:/usr/src/app/thumbs
      - {{ immich_profile_path }}:/usr/src/app/profile
      - /mnt/media:/mnt/media:ro
      - /etc/localtime:/etc/localtime:ro
    depends_on:
      - immich-redis
      - immich-database

  immich-machine-learning:
    image: ghcr.io/immich-app/immich-machine-learning:{{ immich_version }}
    container_name: immich-machine-learning
    restart: unless-stopped
    network_mode: host
    environment:
      - NODE_ENV={{ immich_environment }}
    env_file:
      - {{ immich_docker_env_path }}
    volumes:
      - {{ immich_upload_path }}:/usr/src/app/upload
      - {{ immich_library_path }}:/usr/src/app/library
      - {{ immich_thumb_path }}:/usr/src/app/thumbs
      - {{ immich_profile_path }}:/usr/src/app/profile
      - /etc/localtime:/etc/localtime:ro
    depends_on:
      - immich-redis
      - immich-database

  immich-redis:
    image: redis:7-alpine
    container_name: immich-redis
    restart: unless-stopped
    network_mode: host
    command: redis-server --appendonly yes
    volumes:
      - {{ immich_redis_data_path }}:/data
      - /etc/localtime:/etc/localtime:ro

  immich-database:
    image: tensorchord/pgvecto-rs:pg14-v0.2.0
    container_name: immich-database
    restart: unless-stopped
    network_mode: host
    environment:
      POSTGRES_USER: {{ immich_db_user }}
      POSTGRES_PASSWORD: {{ immich_db_password }}
      POSTGRES_DB: {{ immich_db_name }}
      POSTGRES_INITDB_ARGS: '--data-checksums'
    volumes:
      - {{ immich_db_data_path }}:/var/lib/postgresql/data
      - /etc/localtime:/etc/localtime:ro
    healthcheck:
      test: ['CMD-SHELL', 'pg_isready -d {{ immich_db_name }} -U {{ immich_db_user }}']
      interval: 30s
      timeout: 10s
      retries: 3
      start_period: 60s
