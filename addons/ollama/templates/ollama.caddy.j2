# Ollama API reverse proxy — protected with basic auth
# Only generated when ollama_domain is set.
{% if ollama_domain %}
http://{{ ollama_domain }} {
    basic_auth {
        {{ caddy_auth_user }} {{ caddy_auth_hash }}
    }

    reverse_proxy {{ ollama_bind_address }}:{{ ollama_port }}

    header {
        X-Content-Type-Options "nosniff"
        -Server
    }

    log {
        output file /var/log/caddy/ollama.log {
            roll_size 50mb
            roll_keep 3
        }
        format json
    }
}
{% endif %}
