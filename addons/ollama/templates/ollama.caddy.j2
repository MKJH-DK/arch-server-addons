# Ollama API reverse proxy
# Only enabled when ollama_caddy_enabled=true

{% if ollama_domain %}
{{ ollama_domain }} {
  handle {{ ollama_url_prefix }}/* {
    reverse_proxy {{ ollama_bind_address }}:{{ ollama_port }}
  }

  header {
    X-Content-Type-Options "nosniff"
    -Server
  }

  log {
    output file /var/log/caddy/ollama.log {
      roll_size 50mb
      roll_keep 3
    }
    format json
  }
}
{% else %}
:80 {
  handle {{ ollama_url_prefix }}/* {
    reverse_proxy {{ ollama_bind_address }}:{{ ollama_port }}
  }

  header {
    X-Content-Type-Options "nosniff"
    -Server
  }
}
{% endif %}
