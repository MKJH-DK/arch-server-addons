[Unit]
Description=Ollama - Local LLM Server
After=network-online.target
Wants=network-online.target

[Service]
ExecStart=/usr/local/bin/ollama serve
User={{ ollama_user }}
Group={{ ollama_group }}
Restart=on-failure
RestartSec=5s

# Environment
Environment="OLLAMA_HOST={{ ollama_bind_address }}:{{ ollama_port }}"
Environment="OLLAMA_MODELS={{ ollama_models_path }}"
Environment="OLLAMA_NUM_PARALLEL={{ ollama_num_parallel }}"
Environment="OLLAMA_MAX_LOADED_MODELS={{ ollama_max_loaded_models }}"

# Security hardening
NoNewPrivileges=yes
PrivateTmp=yes
ProtectSystem=strict
ProtectHome=read-only
ReadWritePaths={{ ollama_data_path }}
ReadWritePaths=/tmp

# Resource limits
MemoryMax={{ ollama_memory_max }}

[Install]
WantedBy=multi-user.target
