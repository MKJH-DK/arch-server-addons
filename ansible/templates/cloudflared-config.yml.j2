# Cloudflare Tunnel Configuration
# Generated by Ansible — do not edit manually.
# Re-deploy with deploy-addons.sh to update.

tunnel: {{ cloudflare_tunnel_id }}
credentials-file: {{ cloudflare_credentials_file }}

ingress:
{% for site in obsidian_sites | default([]) %}
{% if site.domain | default('') | length > 0 %}
  - hostname: {{ site.domain }}
    service: http://localhost:80
{% endif %}
{% endfor %}
{% for domain in cloudflare_extra_domains | default([]) %}
{% if domain | length > 0 %}
  - hostname: {{ domain }}
    service: http://localhost:80
{% endif %}
{% endfor %}
{% if immich_domain | default('') | length > 0 %}
  - hostname: {{ immich_domain }}
    service: http://localhost:80
{% endif %}
{% if syncthing_domain | default('') | length > 0 %}
  - hostname: {{ syncthing_domain }}
    service: http://localhost:80
{% endif %}
{% if ollama_domain | default('') | length > 0 %}
  - hostname: {{ ollama_domain }}
    service: http://localhost:80
{% endif %}
{% if admin_domain | default('') | length > 0 %}
  - hostname: {{ admin_domain }}
    service: http://localhost:80
{% endif %}
{% if cloudflare_ssh_domain | default('') | length > 0 %}
  - hostname: {{ cloudflare_ssh_domain }}
    service: ssh://localhost:22
{% endif %}
  - service: http_status:404
