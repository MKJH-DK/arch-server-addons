# Arch Server Addons Configuration
# ============================================================================
# Alle addons er konfigureret til at virke sammen som en samlet stack.
# API-nøgler sættes som env vars i /etc/environment eller brugerens shell.

# ============================================================================
# CLOUDFLARE TUNNEL
# ============================================================================
# Automatisk konfiguration af cloudflared tunnel.
# Tunnel ID og credentials sættes efter første 'cloudflared tunnel create'.
CLOUDFLARE_TUNNEL_ID=""
CLOUDFLARE_CREDENTIALS_FILE=""
# Ekstra domæner (komma-separeret) ud over addon-domæner:
CLOUDFLARE_EXTRA_DOMAINS="humethix.dk"
# SSH adgang via tunnel
CLOUDFLARE_SSH_DOMAIN="ssh.mkjh.dk"

# ============================================================================
# OBSIDIAN WEB (Vault + Syncthing + Quartz CMS)
# ============================================================================
# Synkroniserer din Obsidian vault via Syncthing mellem alle enheder.
# Vault-strukturen bevares som den er — eneste tilføjelse er 05-public/ mappen
# hvorfra Quartz bygger statiske websites (hjemmeside, CV, notes, etc.).
#
# Vault-struktur på serveren:
#   /srv/vault/                    ← hele vaulten (synced)
#   ├── 01-notes/                  ← inbox & hurtige noter
#   ├── 02-knowledge/              ← videnbase & research
#   ├── 03-personal/               ← personlige dokumenter (CV, kontrakter)
#   ├── 04-repos/                  ← git repositories
#   └── 05-public/                 ← Quartz sites (mapper = domænenavne)
#       ├── mkjh.dk/               ← hovedsite
#       └── notes.mkjh.dk/         ← offentlige noter
#
# Per-site konfiguration (titler, domæner) defineres i:
#   addons/obsidian-web/defaults/main.yml → obsidian_sites: [...]
OBSIDIAN_ENABLED=true
OBSIDIAN_VAULT_PATH="/srv/vault"
OBSIDIAN_SYNCTHING_USER="admin"
OBSIDIAN_DOMAIN=""
OBSIDIAN_URL_PREFIX="/wiki"
OBSIDIAN_RENDER_MODE="quartz"
# Syncthing ekstern adgang (basic auth)
SYNCTHING_DOMAIN="syncthing.mkjh.dk"

# ============================================================================
# BACKBLAZE B2 BACKUP
# ============================================================================
BACKBLAZE_ENABLED=true
BACKUP_SCHEDULE="daily"
BACKUP_RETENTION_DAYS=30
# B2 credentials (Application Key med adgang til begge buckets)
BACKUP_B2_KEY_ID="0056b3ac17a44fd0000000002"
BACKUP_B2_APP_KEY="K005g+jD8XVdSu99VMfBJbj2gvF/SRk"
# Backup jobs: foto-collection synkroniseres med Immich, private-vault-files med hele vaulten
BACKUP_JOBS='[{"name":"photos","source":"/srv/immich/uploads","bucket":"foto-collection"},{"name":"vault","source":"/srv/vault","bucket":"private-vault-files"}]'

# ============================================================================
# CGIT (Git web viewer)
# ============================================================================
CGIT_ENABLED=false
CGIT_TITLE="Git Repos"
CGIT_REPO_PATH="/srv/git"
CGIT_URL_PREFIX="/git"

# ============================================================================
# IMMICH (Self-hosted fotostyring)
# ============================================================================
# Bruger Podman med podman-compose (installeres automatisk af addon).
IMMICH_ENABLED=true
IMMICH_DOMAIN="immich.mkjh.dk"
IMMICH_URL_PREFIX="/photos"
IMMICH_DATA_PATH="/srv/immich"
IMMICH_ADMIN_EMAIL=""
IMMICH_VERSION="v2.6.1"

# ============================================================================
# CROWDSEC (Udvidet sikkerhed)
# ============================================================================
CROWDSEC_ENABLED=true
CROWDSEC_DOMAIN=""
CROWDSEC_URL_PREFIX="/security"
CROWDSEC_DATA_PATH="/srv/crowdsec"
CROWDSEC_CONFIG_PATH="/etc/crowdsec"
CROWDSEC_LOG_PATH="/var/log/crowdsec"
CROWDSEC_AGENT_PORT=8080
CROWDSEC_API_PORT=8081
CROWDSEC_FIREWALL_ENABLED=true
CROWDSEC_CADDY_ENABLED=true

# ============================================================================
# SYNCTHING
# ============================================================================
# Syncthing konfigureres via Obsidian Web addon (ovenfor).
# Admin UI: http://localhost:8384
# Data: /var/lib/syncthing
# Enheder parres manuelt via Syncthing UI første gang.

# ============================================================================
# OLLAMA (Lokal LLM server)
# ============================================================================
OLLAMA_ENABLED=true
OLLAMA_BIND_ADDRESS="127.0.0.1"
OLLAMA_PORT=11434
OLLAMA_DATA_PATH="/srv/ollama"
OLLAMA_MEMORY_MAX="8G"
OLLAMA_DEFAULT_MODELS=""
OLLAMA_CADDY_ENABLED=true
OLLAMA_DOMAIN="ollama.mkjh.dk"
OLLAMA_URL_PREFIX="/ollama"

# ============================================================================
# MCP SERVER (Model Context Protocol)
# ============================================================================
# Eksponerer lokale tools (Ollama, repo-analyse, videnbase) til AI-klienter
# som Claude Code, Cursor, Windsurf m.fl. via Model Context Protocol.
MCP_SERVER_ENABLED=true
MCP_SERVER_PORT=8100
MCP_SERVER_BIND_ADDRESS="127.0.0.1"
MCP_SERVER_TRANSPORT="http"
MCP_SERVER_AUTH_ENABLED=true
MCP_SERVER_AUTH_TOKEN=""  # Genereres automatisk hvis tom
# Caddy reverse proxy
MCP_SERVER_CADDY_ENABLED=false
MCP_SERVER_DOMAIN=""
MCP_SERVER_URL_PREFIX="/mcp"
# Tool modules
MCP_TOOL_OLLAMA_ENABLED=true
MCP_TOOL_REPO_DIGEST_ENABLED=true
MCP_TOOL_KNOWLEDGE_FEED_ENABLED=false
MCP_TOOL_KNOWLEDGE_FEED_PATH="/srv/vault/02-knowledge"
MCP_TOOL_HIVE_RESEARCH_ENABLED=false
MCP_TOOL_HIVE_RESEARCH_PATH="/srv/vault/04-repos/01-active/hive-research"

# ============================================================================
# AI CLI TOOLS
# ============================================================================
# API-nøgler sættes i /etc/environment eller brugerens .zshrc:
#   ANTHROPIC_API_KEY=sk-ant-...
#   GEMINI_API_KEY=...
#   OPENAI_API_KEY=sk-...
CLAUDE_CLI_ENABLED=true
GEMINI_CLI_ENABLED=true
SHELLGPT_ENABLED=true
CODEX_ENABLED=true
