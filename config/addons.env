# Arch Server Addons Configuration
# ============================================================================
# Alle addons er konfigureret til at virke sammen som en samlet stack.
# API-nøgler sættes som env vars i /etc/environment eller brugerens shell.

# ============================================================================
# OBSIDIAN WEB (Vault + Syncthing + Quartz CMS)
# ============================================================================
# Synkroniserer din Obsidian vault via Syncthing mellem alle enheder.
# Vault-strukturen bevares som den er — eneste tilføjelse er _public/ mappen
# hvorfra Quartz bygger statiske websites (hjemmeside, CV, notes, etc.).
#
# Vault-struktur på serveren:
#   /srv/vault/                    ← hele vaulten (synced)
#   ├── 01-notes/                  ← inbox & hurtige noter
#   ├── 02-knowledge/              ← videnbase & research
#   ├── 03-personal/               ← personlige dokumenter (CV, kontrakter)
#   ├── 04-repos/                  ← git repositories
#   └── 05-public/                 ← Quartz sites (mapper = domænenavne)
#       ├── mkjh.dk/               ← hovedsite
#       └── notes.mkjh.dk/         ← offentlige noter
#
# Per-site konfiguration (titler, domæner) defineres i:
#   addons/obsidian-web/defaults/main.yml → obsidian_sites: [...]
OBSIDIAN_ENABLED=true
OBSIDIAN_VAULT_PATH="/srv/vault"
OBSIDIAN_SYNCTHING_USER="admin"
OBSIDIAN_DOMAIN=""
OBSIDIAN_URL_PREFIX="/wiki"
OBSIDIAN_RENDER_MODE="quartz"

# ============================================================================
# BACKBLAZE B2 BACKUP
# ============================================================================
# Automatisk krypteret offsite backup af vault, configs og data.
# Kræver: rclone config med B2 credentials (køres manuelt første gang).
BACKBLAZE_ENABLED=false
BACKUP_B2_BUCKET=""                # Sæt dit B2 bucket-navn her
BACKUP_SCHEDULE="daily"
BACKUP_RETENTION_DAYS=30
BACKUP_ENCRYPT=true
BACKUP_PATHS="/srv/vault /srv/git /srv/immich /etc/caddy /etc/crowdsec"

# ============================================================================
# CGIT (Git web viewer)
# ============================================================================
# Lightweight git repository browser via web.
CGIT_ENABLED=false
CGIT_TITLE="Git Repos"
CGIT_REPO_PATH="/srv/git"
CGIT_URL_PREFIX="/git"

# ============================================================================
# IMMICH (Self-hosted fotostyring)
# ============================================================================
# Bruger Podman med podman-compose (installeres automatisk af addon).
IMMICH_ENABLED=true
IMMICH_DOMAIN=""
IMMICH_URL_PREFIX="/photos"
IMMICH_DATA_PATH="/srv/immich"
IMMICH_ADMIN_EMAIL=""              # Sæt din email her
IMMICH_VERSION="latest"

# ============================================================================
# CROWDSEC (Udvidet sikkerhed)
# ============================================================================
# Base-serveren installerer CrowdSec grundopsætning. Denne addon tilføjer:
#   - Dashboard/metrics
#   - Caddy bouncer integration
#   - Automatisk backup af decisions/scenarios
#   - Firewall (nftables) bouncer
CROWDSEC_ENABLED=true
CROWDSEC_DOMAIN=""
CROWDSEC_URL_PREFIX="/security"
CROWDSEC_DATA_PATH="/srv/crowdsec"
CROWDSEC_CONFIG_PATH="/etc/crowdsec"
CROWDSEC_LOG_PATH="/var/log/crowdsec"
CROWDSEC_AGENT_PORT=8080
CROWDSEC_API_PORT=8081
CROWDSEC_FIREWALL_ENABLED=true
CROWDSEC_CADDY_ENABLED=true

# ============================================================================
# SYNCTHING
# ============================================================================
# Syncthing konfigureres via Obsidian Web addon (ovenfor).
# Admin UI: http://localhost:8384
# Data: /var/lib/syncthing
# Enheder parres manuelt via Syncthing UI første gang.

# ============================================================================
# OLLAMA (Lokal LLM server)
# ============================================================================
# Kører LLMs lokalt — bruges som backend for AI CLI tools eller direkte.
OLLAMA_ENABLED=true
OLLAMA_BIND_ADDRESS="127.0.0.1"
OLLAMA_PORT=11434
OLLAMA_DATA_PATH="/srv/ollama"
OLLAMA_MEMORY_MAX="8G"
# Modeller der automatisk pulles ved deploy:
OLLAMA_DEFAULT_MODELS=""
# Caddy reverse proxy (valgfrit — gør API tilgængelig eksternt)
OLLAMA_CADDY_ENABLED=false
OLLAMA_DOMAIN=""
OLLAMA_URL_PREFIX="/ollama"

# ============================================================================
# AI CLI TOOLS
# ============================================================================
# Alle fire AI-assistenter installeres og gøres tilgængelige i terminalen.
# API-nøgler sættes i /etc/environment eller brugerens .zshrc:
#   ANTHROPIC_API_KEY=sk-ant-...
#   GEMINI_API_KEY=...
#   OPENAI_API_KEY=sk-...

# Claude Code (Anthropic) — kommando: claude
CLAUDE_CLI_ENABLED=true

# Gemini CLI (Google) — kommando: gemini
GEMINI_CLI_ENABLED=true

# ShellGPT (shell-gpt) — kommando: sgpt
SHELLGPT_ENABLED=true

# Codex (OpenAI) — kommando: codex
CODEX_ENABLED=true
