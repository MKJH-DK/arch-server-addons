# Arch Server Addons Configuration
# ============================================================================

# OBSIDIAN WEB
# Syncs your Obsidian vault via Syncthing and publishes _public/<site>/ as
# static websites built with Quartz (https://quartz.jzhao.xyz).
#
# Per-site configuration (names, titles, domains) lives in the Ansible role:
#   addons/obsidian-web/defaults/main.yml  →  obsidian_sites: [...]
# Override obsidian_sites in your Ansible inventory to define multiple sites.
OBSIDIAN_ENABLED=true
OBSIDIAN_VAULT_PATH="/srv/obsidian/vault"
OBSIDIAN_SYNCTHING_USER="root"  # User owning vault files and running Syncthing
OBSIDIAN_DOMAIN=""               # Eget domæne (f.eks. "wiki.example.com") eller tom for path-baseret
OBSIDIAN_URL_PREFIX="/wiki"      # URL prefix for path-baseret (når OBSIDIAN_DOMAIN er tom)
OBSIDIAN_RENDER_MODE="client"    # "client" (JS i browser) eller "quartz" (pre-render)

# BACKBLAZE BACKUP
BACKBLAZE_ENABLED=false
BACKUP_B2_BUCKET=""
BACKUP_SCHEDULE="daily"
BACKUP_RETENTION_DAYS=30
BACKUP_ENCRYPT=true
BACKUP_PATHS="/srv /etc/caddy"

# CGIT (Git web viewer)
CGIT_ENABLED=false
CGIT_TITLE="My Git Repos"
CGIT_REPO_PATH="/srv/git"
CGIT_URL_PREFIX="/git"

# IMMICH (Photo management)
# NOTE: Kræver Docker/Docker Compose (base installerer Podman - installer Docker separat)
IMMICH_ENABLED=false
IMMICH_DOMAIN=""
IMMICH_URL_PREFIX="/photos"
IMMICH_DATA_PATH="/srv/immich"
IMMICH_ADMIN_EMAIL="admin@example.com"
IMMICH_VERSION="latest"

# CROWDSEC (Security - addon-udvidelse)
# NOTE: Base-serveren installerer allerede CrowdSec. Denne addon tilføjer
# avanceret konfiguration, dashboard, backup og Caddy-integration.
# Aktivér kun hvis du vil have den udvidede opsætning oveni base-installationen.
CROWDSEC_ENABLED=false
CROWDSEC_DOMAIN=""
CROWDSEC_URL_PREFIX="/security"
CROWDSEC_DATA_PATH="/srv/crowdsec"
CROWDSEC_CONFIG_PATH="/etc/crowdsec"
CROWDSEC_LOG_PATH="/var/log/crowdsec"
CROWDSEC_AGENT_PORT=8080
CROWDSEC_API_PORT=8081
CROWDSEC_FIREWALL_ENABLED=true
CROWDSEC_CADDY_ENABLED=true

# OLLAMA (Lokal LLM server)
# Kører LLMs lokalt på serveren. Bruges som backend for AI CLI tools.
OLLAMA_ENABLED=false
OLLAMA_BIND_ADDRESS="127.0.0.1"
OLLAMA_PORT=11434
OLLAMA_DATA_PATH="/srv/ollama"
OLLAMA_MEMORY_MAX="8G"
# Modeller der automatisk pulles ved deploy (kommasepareret):
# Eksempler: llama3.1:8b, codellama:7b, mistral, qwen2.5-coder:7b
OLLAMA_DEFAULT_MODELS=""
# Caddy reverse proxy (gør Ollama API tilgængelig via web)
OLLAMA_CADDY_ENABLED=false
OLLAMA_DOMAIN=""
OLLAMA_URL_PREFIX="/ollama"

# ============================================================================
# AI CLI TOOLS
# ============================================================================

# CLAUDE CODE (Anthropic's AI coding assistant)
# Kræver: Node.js 18+, ANTHROPIC_API_KEY
CLAUDE_CLI_ENABLED=false

# GEMINI CLI (Google's AI coding assistant)
# Kræver: Node.js 18+, GEMINI_API_KEY
GEMINI_CLI_ENABLED=false

# SHELLGPT (shell-gpt / sgpt - AI i terminalen)
# Kræver: Python 3.9+, OPENAI_API_KEY (eller anden LLM backend)
SHELLGPT_ENABLED=false

# CODEX (OpenAI's AI coding agent)
# Kræver: Node.js 18+, OPENAI_API_KEY
CODEX_ENABLED=false
